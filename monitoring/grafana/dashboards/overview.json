      "type": "stat",
      "targets": [
        { "expr": "pg_stat_database_numbackends{datname=\"ninjabackup\"}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
