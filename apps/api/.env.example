# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://ninja:ninja_secret@localhost:5438/ninjabackup

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long-for-security
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-64-characters-long-too
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ──────────────────────────────────────────
# 32-byte hex key for encrypting storage vault credentials
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Server ──────────────────────────────────────────────
PORT=3038
NODE_ENV=development
CORS_ORIGIN=http://localhost:3039

# ─── Email Notifications (optional) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ninjabackup.io
ALERT_EMAIL=admin@company.com

# ─── Webhook (optional) ─────────────────────────────────
WEBHOOK_URL=

# ─── Dashboard URL ──────────────────────────────────────
DASHBOARD_URL=http://localhost:3039

# ─── Redis (optional - for caching/sessions) ────────────
REDIS_URL=redis://localhost:6338
