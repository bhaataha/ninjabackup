# ════════════════════════════════════════════════════════════
# NinjaBackup — Environment Variables (production)
# Copy to .env (or configure via Coolify secrets) and fill in.
# ════════════════════════════════════════════════════════════

# ── Database
POSTGRES_DB=ninjabackup
POSTGRES_USER=ninja
POSTGRES_PASSWORD=replace-with-strong-password

# ── JWT (generate with: openssl rand -hex 64)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server-side encryption key (32 bytes hex; openssl rand -hex 32)
ENCRYPTION_KEY=

# ── HMAC secrets for download URLs / webhooks (openssl rand -hex 32)
DOWNLOAD_URL_SECRET=
WEBHOOK_SECRET=

# ── URLs (used in CORS, callback URLs, OG metadata, etc.)
PUBLIC_API_URL=https://api.backup.itninja.co.il
DASHBOARD_URL=https://backup.itninja.co.il
NEXT_PUBLIC_API_URL=https://api.backup.itninja.co.il/api/v1

# ── SMTP for email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@itninja.co.il
ALERT_EMAIL=ops@itninja.co.il

# ── Default outbound webhook (optional)
WEBHOOK_URL=

# ── Agent installer manifest (optional — points to a JSON list of builds)
INSTALLER_MANIFEST_URL=
INSTALLER_BASE_URL=https://downloads.ninjabackup.local/agent
AGENT_VERSION=1.0.0

# ── Monitoring stack
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
GRAFANA_ROOT_URL=https://grafana.backup.itninja.co.il
